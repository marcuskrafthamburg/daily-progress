<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Daily Progress v0.2.0</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root {
    --bg: #fafaf7;
    --card: #ffffff;
    --ink: #1a1a1a;
    --muted: #6b6b6b;
    --accent: #e63946;
    --border: #ebebe5;
    --tag-bg: #f3f1ea;
    --c-energie: #e63946;
    --c-motivation: #f4a261;
    --c-wissen: #2a9d8f;
    --c-sicherheit: #457b9d;
    --c-kontakt: #9b5de5;
    --c-spass: #e76f51;
    --h-work: #e63946;
    --h-sleep: #1d3557;
    --h-sport: #2a9d8f;
    --h-frei: #f4d35e;
    --h-empty: #ebebe5;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  html, body { background: var(--bg); color: var(--ink); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; line-height: 1.45; font-size: 15px; }
  body { padding-bottom: 80px; }

  .container { max-width: 720px; margin: 0 auto; padding: 18px 16px; }
  header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  header h1 { font-size: 18px; font-weight: 700; }
  header .version { font-size: 10px; color: var(--muted); font-weight: 400; }
  header button { padding: 6px 11px; font-size: 12px; border: 1px solid var(--border); background: white; border-radius: 6px; cursor: pointer; }

  /* Date nav */
  .date-nav { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 8px 12px; }
  .date-nav button { padding: 6px 10px; border: 1px solid var(--border); background: white; border-radius: 6px; cursor: pointer; font-size: 14px; }
  .date-nav button:disabled { opacity: 0.3; cursor: not-allowed; }
  .date-nav .center { flex: 1; text-align: center; display: flex; flex-direction: column; gap: 2px; }
  .date-nav .center .label { font-size: 14px; font-weight: 600; }
  .date-nav .center .sub { font-size: 11px; color: var(--muted); }
  .date-nav input[type=date] { border: none; background: transparent; font-size: 14px; font-weight: 600; font-family: inherit; text-align: center; cursor: pointer; }
  .date-nav .today-btn { font-size: 11px; padding: 4px 8px; }

  /* Auth screen */
  .auth-card { background: var(--card); padding: 30px 22px; border-radius: 14px; border: 1px solid var(--border); max-width: 380px; margin: 60px auto; text-align: center; }
  .auth-card h2 { margin-bottom: 14px; font-size: 20px; }
  .auth-card p { color: var(--muted); margin-bottom: 18px; font-size: 13px; }
  .auth-card input { width: 100%; padding: 11px 14px; border: 1px solid var(--border); border-radius: 8px; font-size: 15px; margin-bottom: 12px; font-family: inherit; }
  .auth-card button { width: 100%; padding: 11px; background: var(--accent); color: white; border: none; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; }
  .auth-card .ver { margin-top: 14px; font-size: 11px; color: var(--muted); }
  .auth-msg { margin-top: 10px; font-size: 13px; }

  /* Slide nav */
  .slide-nav { display: flex; justify-content: center; gap: 6px; margin-bottom: 18px; }
  .slide-dot { width: 28px; height: 6px; background: var(--border); border-radius: 3px; cursor: pointer; transition: background 0.2s; }
  .slide-dot.active { background: var(--accent); }

  /* Slide */
  .slide { display: none; background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 18px; margin-bottom: 16px; }
  .slide.active { display: block; }
  .slide h2 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--accent); margin-bottom: 14px; }

  /* Hours grid */
  .hour-categories { display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
  .cat-chip { padding: 6px 11px; font-size: 12px; border: 2px solid transparent; border-radius: 16px; cursor: pointer; user-select: none; font-weight: 500; }
  .cat-chip.work { background: var(--h-work); color: white; }
  .cat-chip.sleep { background: var(--h-sleep); color: white; }
  .cat-chip.sport { background: var(--h-sport); color: white; }
  .cat-chip.frei { background: var(--h-frei); color: var(--ink); }
  .cat-chip.empty { background: white; color: var(--muted); border-color: var(--border); }
  .cat-chip.selected { box-shadow: 0 0 0 3px var(--ink); }
  .hour-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 3px; margin-bottom: 14px; }
  .hour-cell { aspect-ratio: 1 / 1.3; background: var(--h-empty); border-radius: 4px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 9px; color: var(--muted); user-select: none; transition: transform 0.05s; }
  .hour-cell:active { transform: scale(0.92); }
  .hour-cell.work { background: var(--h-work); color: white; }
  .hour-cell.sleep { background: var(--h-sleep); color: white; }
  .hour-cell.sport { background: var(--h-sport); color: white; }
  .hour-cell.frei { background: var(--h-frei); color: var(--ink); }
  @media (max-width: 500px) { .hour-grid { grid-template-columns: repeat(6, 1fr); } .hour-cell { aspect-ratio: 1 / 1; font-size: 11px; } }

  .row { display: flex; gap: 10px; align-items: stretch; margin-bottom: 11px; flex-wrap: wrap; }
  .row label { font-size: 12px; color: var(--muted); display: block; margin-bottom: 3px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
  .row .field { flex: 1; min-width: 140px; }
  .row select, .row input[type=text] { width: 100%; padding: 8px 10px; border: 1px solid var(--border); border-radius: 6px; font-size: 14px; font-family: inherit; background: white; }

  /* Slide 2: Curves */
  .curve-toggle { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
  .curve-toggle .ct { padding: 5px 10px; font-size: 11px; border-radius: 14px; border: 2px solid; cursor: pointer; user-select: none; font-weight: 600; }
  .curve-toggle .ct.energie { color: var(--c-energie); border-color: var(--c-energie); }
  .curve-toggle .ct.energie.on { background: var(--c-energie); color: white; }
  .curve-toggle .ct.motivation { color: var(--c-motivation); border-color: var(--c-motivation); }
  .curve-toggle .ct.motivation.on { background: var(--c-motivation); color: white; }
  .curve-toggle .ct.wissen { color: var(--c-wissen); border-color: var(--c-wissen); }
  .curve-toggle .ct.wissen.on { background: var(--c-wissen); color: white; }
  .curve-toggle .ct.sicherheit { color: var(--c-sicherheit); border-color: var(--c-sicherheit); }
  .curve-toggle .ct.sicherheit.on { background: var(--c-sicherheit); color: white; }
  .curve-toggle .ct.kontakt { color: var(--c-kontakt); border-color: var(--c-kontakt); }
  .curve-toggle .ct.kontakt.on { background: var(--c-kontakt); color: white; }
  .curve-toggle .ct.spass { color: var(--c-spass); border-color: var(--c-spass); }
  .curve-toggle .ct.spass.on { background: var(--c-spass); color: white; }

  .chart-wrap { position: relative; width: 100%; aspect-ratio: 16 / 10; background: white; border: 1px solid var(--border); border-radius: 8px; touch-action: none; }
  #chart-svg { width: 100%; height: 100%; display: block; }
  .chart-help { font-size: 11px; color: var(--muted); margin-top: 6px; text-align: center; }

  .point-form { display: none; padding: 10px; background: var(--tag-bg); border-radius: 8px; margin-top: 8px; gap: 8px; flex-wrap: wrap; align-items: center; }
  .point-form.show { display: flex; }
  .point-form input[type=text] { flex: 1; min-width: 140px; padding: 6px 9px; border: 1px solid var(--border); border-radius: 5px; font-size: 13px; }
  .point-form button { padding: 6px 11px; font-size: 12px; border: 1px solid var(--border); background: white; border-radius: 5px; cursor: pointer; }
  .point-form button.del { color: var(--accent); border-color: var(--accent); }

  /* Slide 3 */
  .emoji-grid { display: grid; grid-template-columns: repeat(8, 1fr); gap: 6px; margin-bottom: 12px; }
  @media (max-width: 500px) { .emoji-grid { grid-template-columns: repeat(6, 1fr); } }
  .emoji-cell { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 22px; cursor: pointer; border-radius: 8px; background: var(--tag-bg); user-select: none; }
  .emoji-cell.selected { background: var(--accent); transform: scale(1.1); }
  .emoji-cell:active { transform: scale(0.92); }

  textarea { width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; font-family: inherit; resize: vertical; min-height: 80px; }

  /* Bottom save bar */
  .save-bar { position: fixed; bottom: 0; left: 0; right: 0; background: white; border-top: 1px solid var(--border); padding: 12px 16px; display: flex; gap: 10px; justify-content: space-between; align-items: center; z-index: 50; padding-bottom: calc(12px + env(safe-area-inset-bottom)); }
  .save-bar .nav-btns { display: flex; gap: 8px; }
  .save-bar button.nav { padding: 8px 14px; border: 1px solid var(--border); background: white; border-radius: 8px; cursor: pointer; font-size: 13px; }
  .save-bar button.save { padding: 9px 22px; background: var(--accent); color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 14px; }
  .save-bar .status { font-size: 12px; color: var(--muted); }
  .save-bar .status.ok { color: var(--c-wissen); }
</style>
</head>
<body>

<!-- Auth Screen -->
<div id="auth-screen">
  <div class="auth-card">
    <h2>📊 Daily Progress</h2>
    <p>Email eintragen, du bekommst einen Login-Link per Mail.</p>
    <input type="email" id="auth-email" placeholder="deine@email.de" autocomplete="email">
    <button id="auth-send">Login-Link senden</button>
    <div class="auth-msg" id="auth-msg"></div>
    <div class="ver">v0.2.0</div>
  </div>
</div>

<!-- Main App -->
<div id="app" style="display:none;">
  <div class="container">

    <header>
      <div>
        <h1>Daily Progress <span class="version">v0.2.0</span></h1>
      </div>
      <button id="logout-btn">Logout</button>
    </header>

    <!-- Date Navigation -->
    <div class="date-nav">
      <button id="prev-day">‹</button>
      <div class="center">
        <input type="date" id="date-picker">
        <span class="sub" id="date-sub"></span>
      </div>
      <button id="next-day">›</button>
      <button id="today-btn" class="today-btn">Heute</button>
    </div>

    <div class="slide-nav">
      <div class="slide-dot active" data-slide="0"></div>
      <div class="slide-dot" data-slide="1"></div>
      <div class="slide-dot" data-slide="2"></div>
    </div>

    <!-- Slide 1: Setup -->
    <div class="slide active" data-slide="0">
      <h2>1. Tag · Stunden, Ort, Projekt</h2>

      <label style="font-size:12px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:4px;">Stunden 0–24</label>
      <div class="hour-categories">
        <div class="cat-chip work selected" data-cat="work">Arbeit</div>
        <div class="cat-chip sleep" data-cat="sleep">Schlaf</div>
        <div class="cat-chip sport" data-cat="sport">Sport</div>
        <div class="cat-chip frei" data-cat="frei">Frei</div>
        <div class="cat-chip empty" data-cat="empty">Löschen</div>
      </div>
      <div class="hour-grid" id="hour-grid"></div>

      <div class="row">
        <div class="field">
          <label>Ort</label>
          <select id="loc-select">
            <option value="">— wählen —</option>
            <option>Office</option>
            <option>Kunde</option>
            <option>Homeoffice</option>
            <option>Zürich</option>
            <option value="__custom">Anderer (Freitext)</option>
          </select>
          <input type="text" id="loc-custom" placeholder="Ort eintragen" style="display:none;margin-top:6px;">
        </div>
        <div class="field">
          <label>Projekt</label>
          <input type="text" id="project-input" list="project-list" placeholder="Projekt-Name">
          <datalist id="project-list"></datalist>
        </div>
      </div>
    </div>

    <!-- Slide 2: Curves -->
    <div class="slide" data-slide="1">
      <h2>2. Werte über Tagesverlauf</h2>

      <div class="curve-toggle" id="curve-toggle">
        <div class="ct energie on" data-curve="energie">Energie/Motivation</div>
        <div class="ct wissen on" data-curve="wissen">Wissen</div>
        <div class="ct sicherheit on" data-curve="sicherheit">Selbstbewusstsein</div>
        <div class="ct kontakt on" data-curve="kontakt">Kontakt</div>
        <div class="ct spass on" data-curve="spass">Frust/Spaß</div>
      </div>

      <div class="chart-wrap">
        <svg id="chart-svg" viewBox="0 0 800 500" preserveAspectRatio="none"></svg>
      </div>
      <div class="chart-help">Klick auf eine Linie = Punkt setzen · Punkte ziehen · Klick auf Punkt = Kommentar</div>

      <div class="point-form" id="point-form">
        <input type="text" id="point-comment" placeholder="z.B. Team-Meeting">
        <button id="point-save">OK</button>
        <button id="point-delete" class="del">Löschen</button>
      </div>
    </div>

    <!-- Slide 3: Extras -->
    <div class="slide" data-slide="2">
      <h2>3. Tages-Stempel</h2>

      <label style="font-size:12px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:6px;">Emoji für heute</label>
      <div class="emoji-grid" id="emoji-grid"></div>

      <label style="font-size:12px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:4px;">Notizen</label>
      <textarea id="notes" placeholder="Was war heute? Eckpunkte, Gedanken, Ärgernisse, Highlights…"></textarea>
    </div>

  </div>

  <div class="save-bar">
    <div class="nav-btns">
      <button class="nav" id="prev-slide">‹</button>
      <button class="nav" id="next-slide">›</button>
    </div>
    <span class="status" id="save-status"></span>
    <button class="save" id="save-btn">Speichern</button>
  </div>
</div>

<script>
// ============= CONFIG =============
const APP_VERSION = '0.2.0';
const SUPABASE_URL = 'https://vmoxqrmzjsjcehadztzg.supabase.co';
const SUPABASE_KEY = 'sb_publishable_iP-_JeEw67YduQ55qE7HVA_Xdlg59xi';
const supa = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

// ============= STATE =============
const CURVES = ['energie','wissen','sicherheit','kontakt','spass'];
const CURVE_LABELS = { energie:'Energie/Motivation', wissen:'Wissen', sicherheit:'Selbstbewusstsein', kontakt:'Kontakt/Austausch', spass:'Frust/Spaß' };
const CURVE_COLORS = { energie:'#e63946', wissen:'#2a9d8f', sicherheit:'#457b9d', kontakt:'#9b5de5', spass:'#e76f51' };
const EMOJIS = ['😀','😊','🙂','😐','😕','😣','😤','😴','🥱','🧠','🔥','💪','🎯','🌧','☀️','🌪','💤','🧘','🎉','😎','🤔','🤯','🥵','🥶','🚀','🎲','📚','💼','✈️','🏠','🤝','🤖'];

let state = {
  date: todayISO(),
  hours: {},
  location: '',
  project: '',
  curves: {},
  visibleCurves: new Set(CURVES),
  day_emoji: '',
  notes: ''
};
let projectList = [];
let currentSlide = 0;
let selectedCat = 'work';
let user = null;
let entryId = null;
let selectedPoint = null;
let isDirty = false;

// ============= AUTH =============
async function checkAuth() {
  const { data: { session } } = await supa.auth.getSession();
  if (session) {
    user = session.user;
    showApp();
  } else {
    showAuth();
  }
}

function showAuth() {
  document.getElementById('auth-screen').style.display = 'block';
  document.getElementById('app').style.display = 'none';
}

async function showApp() {
  document.getElementById('auth-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  await loadProjects();
  await loadEntry();
  initUI();
}

document.getElementById('auth-send').addEventListener('click', async () => {
  const email = document.getElementById('auth-email').value.trim();
  if (!email) return;
  const msg = document.getElementById('auth-msg');
  msg.textContent = 'Sende…';
  const { error } = await supa.auth.signInWithOtp({ email, options: { emailRedirectTo: window.location.href } });
  msg.textContent = error ? ('Fehler: ' + error.message) : 'Mail unterwegs. Klick im Postfach auf den Link.';
});

document.getElementById('logout-btn').addEventListener('click', async () => {
  await supa.auth.signOut();
  location.reload();
});

supa.auth.onAuthStateChange((event, session) => {
  if (event === 'SIGNED_IN' && session) { user = session.user; showApp(); }
});

// ============= DATA =============
function todayISO() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
function formatGerman(iso) {
  const [y,m,d] = iso.split('-');
  const day = ['So','Mo','Di','Mi','Do','Fr','Sa'][new Date(iso).getDay()];
  return `${day}, ${d}.${m}.${y.slice(2)}`;
}
function shiftDate(iso, days) {
  const d = new Date(iso);
  d.setDate(d.getDate() + days);
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
function isFuture(iso) {
  return iso > todayISO();
}

async function loadProjects() {
  const { data } = await supa.from('projects').select('name').order('created_at', { ascending: false });
  projectList = (data || []).map(r => r.name);
  const dl = document.getElementById('project-list');
  dl.innerHTML = projectList.map(n => `<option value="${n}">`).join('');
}

async function ensureProject(name) {
  if (!name || projectList.includes(name)) return;
  await supa.from('projects').insert({ user_id: user.id, name });
  projectList.push(name);
}

function resetState() {
  state.hours = {};
  state.location = '';
  state.project = '';
  state.curves = {};
  CURVES.forEach(c => state.curves[c] = { avg: 5, points: [] });
  state.day_emoji = '';
  state.notes = '';
  entryId = null;
  isDirty = false;
}

async function loadEntry() {
  resetState();
  const { data } = await supa.from('daily_entries').select('*').eq('date', state.date).maybeSingle();
  if (data) {
    entryId = data.id;
    state.hours = data.hours || {};
    state.location = data.location || '';
    state.project = data.project || '';
    state.curves = data.curves || {};
    CURVES.forEach(c => { if (!state.curves[c]) state.curves[c] = { avg: 5, points: [] }; });
    state.day_emoji = data.day_emoji || '';
    state.notes = data.notes || '';
  }
}

async function saveEntry() {
  await ensureProject(state.project);
  const payload = {
    user_id: user.id,
    date: state.date,
    hours: state.hours,
    location: state.location,
    project: state.project,
    curves: state.curves,
    day_emoji: state.day_emoji,
    notes: state.notes
  };
  const status = document.getElementById('save-status');
  status.textContent = 'Speichere…';
  status.className = 'status';
  let res;
  if (entryId) {
    res = await supa.from('daily_entries').update(payload).eq('id', entryId).select().single();
  } else {
    res = await supa.from('daily_entries').insert(payload).select().single();
  }
  if (res.error) {
    status.textContent = '❌ ' + res.error.message;
  } else {
    entryId = res.data.id;
    isDirty = false;
    status.textContent = '✓ Gespeichert';
    status.className = 'status ok';
    setTimeout(() => status.textContent = '', 3000);
  }
}

// ============= UI INIT =============
function initUI() {
  refreshDateUI();
  buildHourGrid();
  buildEmojiGrid();
  initCategoryChips();
  initLocationSelect();
  initProjectInput();
  initCurveToggles();
  initSlideNav();
  initSaveBtn();
  initDateNav();
  drawChart();
}

// ----- Date Navigation -----
function refreshDateUI() {
  document.getElementById('date-picker').value = state.date;
  document.getElementById('date-picker').max = todayISO();
  document.getElementById('date-sub').textContent = formatGerman(state.date) + (state.date === todayISO() ? ' · heute' : '');
  document.getElementById('next-day').disabled = state.date >= todayISO();
}

async function changeDate(newDate) {
  if (isFuture(newDate)) return;
  if (isDirty) {
    if (!confirm('Du hast ungespeicherte Änderungen. Trotzdem wechseln?')) return;
  }
  state.date = newDate;
  await loadEntry();
  refreshUIAfterDateChange();
}

function refreshUIAfterDateChange() {
  refreshDateUI();
  buildHourGrid();
  buildEmojiGrid();
  // Refresh location select
  const sel = document.getElementById('loc-select');
  const custom = document.getElementById('loc-custom');
  custom.style.display = 'none';
  custom.value = '';
  sel.value = '';
  if (state.location) {
    if (['Office','Kunde','Homeoffice','Zürich'].includes(state.location)) {
      sel.value = state.location;
    } else {
      sel.value = '__custom';
      custom.style.display = 'block';
      custom.value = state.location;
    }
  }
  document.getElementById('project-input').value = state.project;
  document.getElementById('notes').value = state.notes;
  drawChart();
}

function initDateNav() {
  document.getElementById('prev-day').addEventListener('click', () => changeDate(shiftDate(state.date, -1)));
  document.getElementById('next-day').addEventListener('click', () => {
    const next = shiftDate(state.date, 1);
    if (!isFuture(next)) changeDate(next);
  });
  document.getElementById('today-btn').addEventListener('click', () => changeDate(todayISO()));
  document.getElementById('date-picker').addEventListener('change', (e) => {
    if (e.target.value && !isFuture(e.target.value)) changeDate(e.target.value);
    else e.target.value = state.date;
  });
}

// ----- Hours -----
function buildHourGrid() {
  const grid = document.getElementById('hour-grid');
  grid.innerHTML = '';
  for (let h = 0; h < 24; h++) {
    const cell = document.createElement('div');
    cell.className = 'hour-cell ' + (state.hours[h] || '');
    cell.dataset.hour = h;
    cell.textContent = h;
    cell.addEventListener('click', () => setHour(h));
    grid.appendChild(cell);
  }
}

function setHour(h) {
  if (selectedCat === 'empty') delete state.hours[h];
  else state.hours[h] = selectedCat;
  const cell = document.querySelector(`.hour-cell[data-hour="${h}"]`);
  cell.className = 'hour-cell ' + (state.hours[h] || '');
  isDirty = true;
  if (currentSlide === 1) drawChart();
}

function initCategoryChips() {
  document.querySelectorAll('.cat-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.cat-chip').forEach(c => c.classList.remove('selected'));
      chip.classList.add('selected');
      selectedCat = chip.dataset.cat;
    });
  });
}

function initLocationSelect() {
  const sel = document.getElementById('loc-select');
  const custom = document.getElementById('loc-custom');
  if (state.location && ['Office','Kunde','Homeoffice','Zürich'].includes(state.location)) {
    sel.value = state.location;
  } else if (state.location) {
    sel.value = '__custom';
    custom.style.display = 'block';
    custom.value = state.location;
  }
  sel.addEventListener('change', () => {
    if (sel.value === '__custom') {
      custom.style.display = 'block';
      state.location = custom.value;
    } else {
      custom.style.display = 'none';
      state.location = sel.value;
    }
    isDirty = true;
  });
  custom.addEventListener('input', () => { state.location = custom.value; isDirty = true; });
}

function initProjectInput() {
  const inp = document.getElementById('project-input');
  inp.value = state.project;
  inp.addEventListener('input', () => { state.project = inp.value; isDirty = true; });
}

function buildEmojiGrid() {
  const grid = document.getElementById('emoji-grid');
  grid.innerHTML = '';
  EMOJIS.forEach(e => {
    const cell = document.createElement('div');
    cell.className = 'emoji-cell' + (state.day_emoji === e ? ' selected' : '');
    cell.textContent = e;
    cell.addEventListener('click', () => {
      state.day_emoji = state.day_emoji === e ? '' : e;
      grid.querySelectorAll('.emoji-cell').forEach(c => c.classList.remove('selected'));
      if (state.day_emoji) cell.classList.add('selected');
      isDirty = true;
    });
    grid.appendChild(cell);
  });
  const notes = document.getElementById('notes');
  notes.value = state.notes;
  notes.addEventListener('input', () => { state.notes = notes.value; isDirty = true; });
}

function initCurveToggles() {
  document.querySelectorAll('.ct').forEach(t => {
    t.addEventListener('click', () => {
      const c = t.dataset.curve;
      if (state.visibleCurves.has(c)) { state.visibleCurves.delete(c); t.classList.remove('on'); }
      else { state.visibleCurves.add(c); t.classList.add('on'); }
      drawChart();
    });
  });
}

function initSlideNav() {
  document.querySelectorAll('.slide-dot').forEach(d => {
    d.addEventListener('click', () => goToSlide(parseInt(d.dataset.slide)));
  });
  document.getElementById('prev-slide').addEventListener('click', () => goToSlide(currentSlide - 1));
  document.getElementById('next-slide').addEventListener('click', () => goToSlide(currentSlide + 1));
}

function goToSlide(n) {
  if (n < 0 || n > 2) return;
  currentSlide = n;
  document.querySelectorAll('.slide').forEach(s => s.classList.toggle('active', parseInt(s.dataset.slide) === n));
  document.querySelectorAll('.slide-dot').forEach(d => d.classList.toggle('active', parseInt(d.dataset.slide) === n));
  if (n === 1) drawChart();
}

function initSaveBtn() {
  document.getElementById('save-btn').addEventListener('click', saveEntry);
}

// ============= CHART (SVG) =============
const CHART = { w: 800, h: 500, padL: 36, padR: 12, padT: 18, padB: 32 };

function chartX(t) { return CHART.padL + (t / 24) * (CHART.w - CHART.padL - CHART.padR); }
function chartY(v) { return CHART.padT + (1 - v / 10) * (CHART.h - CHART.padT - CHART.padB); }
function invX(x) { return ((x - CHART.padL) / (CHART.w - CHART.padL - CHART.padR)) * 24; }
function invY(y) { return (1 - (y - CHART.padT) / (CHART.h - CHART.padT - CHART.padB)) * 10; }

function drawChart() {
  const svg = document.getElementById('chart-svg');
  let html = '';

  // Hour bg
  for (let h = 0; h < 24; h++) {
    const cat = state.hours[h];
    const color = cat === 'work' ? '#e6394620' : cat === 'sleep' ? '#1d355720' : cat === 'sport' ? '#2a9d8f20' : cat === 'frei' ? '#f4d35e30' : 'transparent';
    if (color !== 'transparent') {
      html += `<rect x="${chartX(h)}" y="${CHART.padT}" width="${chartX(h+1) - chartX(h)}" height="${CHART.h - CHART.padT - CHART.padB}" fill="${color}"/>`;
    }
  }

  // Grid
  for (let v = 0; v <= 10; v += 2) {
    html += `<line x1="${CHART.padL}" y1="${chartY(v)}" x2="${CHART.w - CHART.padR}" y2="${chartY(v)}" stroke="#ebebe5" stroke-width="1"/>`;
    html += `<text x="${CHART.padL - 6}" y="${chartY(v) + 4}" font-size="11" fill="#999" text-anchor="end">${v}</text>`;
  }
  for (let h = 0; h <= 24; h += 3) {
    html += `<text x="${chartX(h)}" y="${CHART.h - 10}" font-size="11" fill="#999" text-anchor="middle">${h}</text>`;
  }

  // Curves
  CURVES.forEach(c => {
    if (!state.visibleCurves.has(c)) return;
    const data = state.curves[c] || { avg: 5, points: [] };
    const color = CURVE_COLORS[c];
    if (data.points.length === 0) {
      html += `<line x1="${chartX(0)}" y1="${chartY(data.avg)}" x2="${chartX(24)}" y2="${chartY(data.avg)}" stroke="${color}" stroke-width="2.5" stroke-linecap="round" data-curve="${c}" class="curve-line" style="cursor:pointer;"/>`;
    } else {
      let d = `M ${chartX(0)} ${chartY(data.avg)} `;
      data.points.slice().sort((a,b) => a.t - b.t).forEach(p => { d += `L ${chartX(p.t)} ${chartY(p.v)} `; });
      d += `L ${chartX(24)} ${chartY(data.avg)}`;
      html += `<path d="${d}" stroke="${color}" stroke-width="2.5" fill="none" stroke-linecap="round" data-curve="${c}" class="curve-line" style="cursor:pointer;"/>`;
    }
    data.points.forEach((p, i) => {
      html += `<circle cx="${chartX(p.t)}" cy="${chartY(p.v)}" r="6" fill="${color}" stroke="white" stroke-width="2" data-curve="${c}" data-idx="${i}" class="curve-point" style="cursor:grab;"/>`;
      if (p.note) {
        html += `<text x="${chartX(p.t)}" y="${chartY(p.v) - 10}" font-size="10" fill="${color}" text-anchor="middle">${escapeText(p.note.slice(0, 14))}</text>`;
      }
    });
  });

  svg.innerHTML = html;
  attachChartHandlers();
}

function escapeText(s) { return s.replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c])); }

function attachChartHandlers() {
  const svg = document.getElementById('chart-svg');
  svg.querySelectorAll('.curve-line').forEach(el => {
    el.addEventListener('click', (e) => {
      const c = el.dataset.curve;
      const { x, y } = svgCoords(svg, e);
      const t = Math.max(0, Math.min(24, invX(x)));
      const v = Math.max(0, Math.min(10, invY(y)));
      state.curves[c].points.push({ t: Math.round(t * 4) / 4, v: Math.round(v * 10) / 10 });
      isDirty = true;
      drawChart();
    });
  });
  svg.querySelectorAll('.curve-point').forEach(el => {
    let dragging = false;
    let didDrag = false;
    el.addEventListener('mousedown', startDrag);
    el.addEventListener('touchstart', (e) => { e.preventDefault(); startDrag(e); });

    function startDrag(e) {
      dragging = true;
      didDrag = false;
      const move = (ev) => {
        if (!dragging) return;
        didDrag = true;
        const { x, y } = svgCoords(svg, ev);
        const t = Math.max(0, Math.min(24, invX(x)));
        const v = Math.max(0, Math.min(10, invY(y)));
        const c = el.dataset.curve;
        const i = parseInt(el.dataset.idx);
        state.curves[c].points[i] = { ...state.curves[c].points[i], t: Math.round(t*4)/4, v: Math.round(v*10)/10 };
        isDirty = true;
        drawChart();
      };
      const end = () => {
        if (!didDrag) {
          openPointForm(el.dataset.curve, parseInt(el.dataset.idx));
        }
        dragging = false;
        document.removeEventListener('mousemove', move);
        document.removeEventListener('touchmove', move);
        document.removeEventListener('mouseup', end);
        document.removeEventListener('touchend', end);
      };
      document.addEventListener('mousemove', move);
      document.addEventListener('touchmove', move, { passive: false });
      document.addEventListener('mouseup', end);
      document.addEventListener('touchend', end);
    }
  });
}

function svgCoords(svg, e) {
  const pt = svg.createSVGPoint();
  const t = e.touches ? e.touches[0] : e;
  pt.x = t.clientX; pt.y = t.clientY;
  const ctm = svg.getScreenCTM().inverse();
  const p = pt.matrixTransform(ctm);
  return { x: p.x, y: p.y };
}

function openPointForm(curve, idx) {
  selectedPoint = { curve, idx };
  const p = state.curves[curve].points[idx];
  document.getElementById('point-form').classList.add('show');
  document.getElementById('point-comment').value = p.note || '';
  document.getElementById('point-comment').focus();
}

document.getElementById('point-save').addEventListener('click', () => {
  if (!selectedPoint) return;
  const note = document.getElementById('point-comment').value.trim();
  state.curves[selectedPoint.curve].points[selectedPoint.idx].note = note;
  document.getElementById('point-form').classList.remove('show');
  selectedPoint = null;
  isDirty = true;
  drawChart();
});

document.getElementById('point-delete').addEventListener('click', () => {
  if (!selectedPoint) return;
  state.curves[selectedPoint.curve].points.splice(selectedPoint.idx, 1);
  document.getElementById('point-form').classList.remove('show');
  selectedPoint = null;
  isDirty = true;
  drawChart();
});

